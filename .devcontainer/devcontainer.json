{
  "name": "trevor",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "minikube": "none",
      "helm": "latest",
      "kubectl": "latest"
    },
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "mounts": [
    "type=bind,source=${localEnv:HOME}/.config/opencode,target=/home/vscode/.config/opencode,consistency=cached",
    "type=bind,source=${localEnv:HOME}/.local/share/opencode,target=/home/vscode/.local/share/opencode,consistency=cached"
  ],
  "initializeCommand": "mkdir -p ${localEnv:HOME}/.config/opencode ${localEnv:HOME}/.local/share/opencode",
  "postCreateCommand": ".devcontainer/post-create.sh",
  "forwardPorts": [8000, 8080, 8333, 5432, 6379],
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.python",
        "redhat.vscode-yaml",
        "tilt-dev.tiltfile"
      ],
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python"
      }
    }
  }
}
