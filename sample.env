# sample.env — copied to .env automatically by post-create.sh on devcontainer creation.
# DO NOT commit .env — it is gitignored.

# ── Database ─────────────────────────────────────────────────────────────────
# Postgres from the Tilt dev stack (port-forwarded from k3d).
DATABASE_URL=postgresql+asyncpg://trevor:trevor@localhost:5432/trevor

# ── Redis / ARQ ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
DEV_AUTH_BYPASS=false
# Browser-facing Keycloak URL (used in auth redirects and as JWT issuer).
KEYCLOAK_URL=http://localhost:8080
# Internal URL for server-side OIDC calls (JWKS, token exchange).
# Leave empty when running locally — localhost:8080 is reachable for both.
# Set to http://keycloak:8080 only inside the k8s cluster (done via Tiltfile).
KEYCLOAK_INTERNAL_URL=
KEYCLOAK_REALM=karectl
KEYCLOAK_CLIENT_ID=trevor
# Keycloak admin credentials (used by post-create.sh to configure the realm).
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── S3 / SeaweedFS ────────────────────────────────────────────────────────────
# SeaweedFS S3 gateway port-forwarded from k3d via Tilt.
S3_ENDPOINT_URL=http://localhost:8333
S3_ACCESS_KEY_ID=devaccess
S3_SECRET_ACCESS_KEY=devsecret
S3_QUARANTINE_BUCKET=trevor-quarantine
S3_RELEASE_BUCKET=trevor-release
S3_REGION=us-east-1

# ── Agent (LLM review) ────────────────────────────────────────────────────────
AGENT_LLM_ENABLED=false
AGENT_OPENAI_BASE_URL=http://localhost:11434/v1
AGENT_MODEL_NAME=gpt-4o
AGENT_API_KEY=
AGENT_MIN_CELL_COUNT=10
AGENT_DOMINANCE_P=70

# ── Release ───────────────────────────────────────────────────────────────────
PRESIGNED_URL_TTL=604800

# ── Admin ─────────────────────────────────────────────────────────────────────
STUCK_REQUEST_HOURS=72

# ── App ───────────────────────────────────────────────────────────────────────
APP_TITLE=trevor
APP_VERSION=0.1.0
LOG_LEVEL=DEBUG
LOG_FORMAT=console
# SECRET_KEY must be a strong random value in production.
SECRET_KEY=dev-secret-key-change-in-prod
MAX_UPLOAD_SIZE_MB=500

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=trevor
