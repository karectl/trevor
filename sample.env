# sample.env — copy to .env and fill in values for local development.
# DO NOT commit .env — it is gitignored.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./local/trevor.db

# ── Redis / ARQ ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
# Set DEV_AUTH_BYPASS=true to skip Keycloak JWT validation in local dev/tests.
DEV_AUTH_BYPASS=false
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=karectl
KEYCLOAK_CLIENT_ID=trevor

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
# Leave S3_ENDPOINT_URL empty to use AWS S3. Set to MinIO URL for local dev.
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=changeme
S3_SECRET_ACCESS_KEY=changeme
S3_QUARANTINE_BUCKET=trevor-quarantine
S3_RELEASE_BUCKET=trevor-release
S3_REGION=us-east-1

# ── Agent (LLM review) ────────────────────────────────────────────────────────
AGENT_LLM_ENABLED=false
AGENT_OPENAI_BASE_URL=http://localhost:11434/v1
AGENT_MODEL_NAME=gpt-4o
AGENT_API_KEY=changeme
AGENT_MIN_CELL_COUNT=10
AGENT_DOMINANCE_P=70

# ── Release ───────────────────────────────────────────────────────────────────
PRESIGNED_URL_TTL=604800

# ── Admin ─────────────────────────────────────────────────────────────────────
STUCK_REQUEST_HOURS=72

# ── App ───────────────────────────────────────────────────────────────────────
APP_TITLE=trevor
APP_VERSION=0.1.0
LOG_LEVEL=INFO
LOG_FORMAT=console
# SECRET_KEY must be a strong random value in production.
SECRET_KEY=dev-secret-key-change-in-prod
MAX_UPLOAD_SIZE_MB=500

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=trevor
